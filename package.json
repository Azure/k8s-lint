{
   "name": "k8s-lint-action",
   "version": "3.0.1",
   "private": true,
   "type": "module",
   "main": "lib/index.js",
   "scripts": {
      "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node24 --outfile=lib/index.js",
      "test": "vitest run",
      "test-coverage": "vitest run --coverage",
      "format": "prettier --write .",
      "format-check": "prettier --check .",
      "prepare": "husky"
   },
   "keywords": [
      "actions"
   ],
   "author": "GitHub",
   "license": "MIT",
   "dependencies": {
      "@actions/core": "^2.0.2",
      "@actions/exec": "^2.0.0",
      "@actions/tool-cache": "3.0.0",
      "husky": "^9.1.7"
   },
   "devDependencies": {
      "@types/node": "^25.0.9",
      "prettier": "^3.8.0",
      "typescript": "5.9.3",
      "esbuild": "^0.25.11",
      "vitest": "^3.2.4",
      "@vitest/coverage-v8": "^3.2.4"
   }
}
